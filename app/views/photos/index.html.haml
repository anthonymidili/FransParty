%h1.fw-bold.mb-4 🎉 Fran's Sweet 16 Photos

- if notice
  .alert.alert-success.alert-dismissible.fade.show
    = notice
    %button.btn-close{"data-bs-dismiss" => "alert"}

- if @images.any?
  #photos-container{data: { controller: "infinite-scroll", "infinite-scroll-next-page-value": @page + 1 }}
    .row.g-3#photos-grid
      = render "photos", images: @images
    - if @has_more
      = render "sentinel"
- else
  .text-center.py-5
    %i.bi.bi-images.display-1.text-muted
    %p.text-muted.mt-3 No photos yet. Be the first to upload!

/ Fullscreen photo modal
#photoModal.modal.fade{"tabindex" => "-1", "aria-hidden" => "true"}
  .modal-dialog.modal-fullscreen
    .modal-content.bg-black
      .modal-header.border-0
        %button.btn-close.btn-close-white{"data-bs-dismiss" => "modal", "aria-label" => "Close"}/
      .modal-body.d-flex.align-items-center.justify-content-center.p-2
        %img#modalPhoto{src: "", class: "img-fluid", style: "max-height: 90vh; object-fit: contain;"}
