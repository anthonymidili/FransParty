.row.justify-content-center
  .col-md-6
    .card.shadow-sm
      .card-body
        %h2.card-title.fw-bold.mb-4 Upload Photos

        = form_with model: @photo, class: "needs-validation" do |f|
          .mb-3
            = f.label :images, "Select Photos", class: "form-label"
            = f.file_field :images, multiple: true, accept: "image/*", class: "form-control", required: true
            %div.form-text Select one or more photos to upload.

          .mb-3
            = f.label :caption, "Caption (optional)", class: "form-label"
            = f.text_field :caption, class: "form-control", placeholder: "Add a caption..."

          - if @photo.errors.any?
            .alert.alert-danger
              %ul.mb-0
                - @photo.errors.full_messages.each do |msg|
                  %li= msg

          .d-flex.gap-2
            = f.submit "Upload", class: "btn btn-pink"
            = link_to "Cancel", photos_path, class: "btn btn-outline-secondary"
